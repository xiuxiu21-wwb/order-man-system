.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding: 60rpx 40rpx;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 44rpx;
  font-weight: 700;
  color: white;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.form {
  background: white;
  border-radius: 24rpx;
  padding: 50rpx 40rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.input {
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.btn-primary {
  height: 88rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
}

.link-group {
  text-align: center;
  margin-top: 40rpx;
}

.link {
  color: #667eea;
  font-size: 28rpx;
}

.required {
  color: #ff4444;
  margin-left: 4rpx;
}

.uid-tip {
  font-size: 24rpx;
  color: #f59e0b;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* 验证码样式 */
.verify-code-item {
  margin-bottom: 24rpx;
}

.verify-code-area {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.verify-code-input {
  flex: 1;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.verify-code-image {
  width: 160rpx;
  height: 88rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #e5e5e5;
}

.verify-code-image image {
  width: 100%;
  height: 100%;
}

.verify-code-placeholder {
  font-size: 22rpx;
  color: #999;
}