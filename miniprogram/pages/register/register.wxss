page {
  background: #fff7ed;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
}

.header-section {
  padding-top: 100rpx;
  padding-bottom: 60rpx;
  padding-left: 60rpx;
  position: relative;
  z-index: 2;
}

.title {
  font-size: 56rpx;
  font-weight: 800;
  color: #c2410c;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 32rpx;
  color: #ea580c;
  display: flex;
  align-items: center;
  font-weight: 600;
}

.user-type {
  opacity: 0.6;
  transition: all 0.3s;
  padding: 10rpx 0;
}

.user-type.active {
  opacity: 1;
  font-size: 36rpx;
  position: relative;
}

.user-type.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 6rpx;
  background: #ea580c;
  border-radius: 4rpx;
}

.divider {
  margin: 0 20rpx;
  opacity: 0.4;
  font-size: 28rpx;
}

.register-card {
  flex: 1;
  background: white;
  border-top-left-radius: 60rpx;
  border-top-right-radius: 60rpx;
  box-shadow: 0 -10rpx 40rpx rgba(251, 146, 60, 0.1);
  position: relative;
  z-index: 10;
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  overflow: hidden;
}

.form-scroll {
  height: 100%;
  box-sizing: border-box;
  padding: 60rpx;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.input-group {
  margin-bottom: 36rpx;
}

.input-label {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 600;
  margin-bottom: 12rpx;
  margin-left: 10rpx;
}

.input-wrapper {
  background: #f9fafb;
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  background: white;
  border-color: #fb923c;
  box-shadow: 0 0 0 6rpx rgba(251, 146, 60, 0.15);
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1f2937;
  height: 48rpx;
}

.placeholder {
  color: #9ca3af;
  font-size: 28rpx;
}

/* 验证码特殊样式 */
.verify-code-row {
  display: flex;
  gap: 20rpx;
}

.code-input {
  flex: 1;
}

.verify-code-box {
  width: 200rpx;
  height: 100rpx; /* 与 input-wrapper 高度一致 */
  background: #f3f4f6;
  border-radius: 30rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-img {
  width: 100%;
  height: 100%;
}

.code-placeholder {
  font-size: 24rpx;
  color: #9ca3af;
}

.uid-tip {
  font-size: 24rpx;
  color: #f59e0b;
  margin-top: 10rpx;
  margin-left: 10rpx;
}

.picker {
  background: #f9fafb;
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
  font-size: 30rpx;
  color: #1f2937;
}

.picker.placeholder {
  color: #9ca3af;
}

.register-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-radius: 40rpx;
  padding: 0;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 40rpx;
  box-shadow: 0 12rpx 24rpx rgba(234, 88, 12, 0.25);
  border: none;
}

.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 12rpx rgba(234, 88, 12, 0.2);
}

.footer-links {
  margin-top: 30rpx;
  text-align: center;
  padding-bottom: 40rpx;
}

.login-link {
  font-size: 28rpx;
  color: #6b7280;
  padding: 20rpx;
}

.highlight {
  color: #ea580c;
  font-weight: 700;
  margin-left: 10rpx;
}

/* 装饰圆圈 */
.decoration-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  z-index: 1;
}

.circle-1 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(253, 186, 116, 0.3);
  top: -50rpx;
  right: -50rpx;
}

.circle-2 {
  width: 200rpx;
  height: 200rpx;
  background: rgba(254, 215, 170, 0.4);
  top: 10%;
  left: 20%;
}