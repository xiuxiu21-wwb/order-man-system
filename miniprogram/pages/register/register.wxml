<view class="container">
  <view class="header-section">
    <view class="title">创建账号</view>
    <view class="subtitle">
      <text class="user-type {{userType === 'elder' ? 'active' : ''}}" bindtap="switchUserType" data-type="elder">老人注册</text>
      <text class="divider">|</text>
      <text class="user-type {{userType === 'family' ? 'active' : ''}}" bindtap="switchUserType" data-type="family">子女注册</text>
    </view>
  </view>

  <view class="register-card">
    <scroll-view scroll-y class="form-scroll">
      <view class="input-group">
        <view class="input-label">姓名</view>
        <view class="input-wrapper">
          <input class="input" placeholder="请输入真实姓名" placeholder-class="placeholder" value="{{name}}" bindinput="onNameInput" />
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">手机号</view>
        <view class="input-wrapper">
          <input class="input" placeholder="请输入手机号" placeholder-class="placeholder" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" />
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">设置密码</view>
        <view class="input-wrapper">
          <input class="input" type="password" placeholder="6位以上密码" placeholder-class="placeholder" value="{{password}}" bindinput="onPasswordInput" />
        </view>
      </view>

      <view class="input-group">
        <view class="input-label">确认密码</view>
        <view class="input-wrapper">
          <input class="input" type="password" placeholder="再次输入密码" placeholder-class="placeholder" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
        </view>
      </view>

      <!-- 验证码 -->
      <view class="input-group">
        <view class="input-label">验证码</view>
        <view class="verify-code-row">
          <view class="input-wrapper code-input">
            <input 
              class="input" 
              placeholder="4位验证码" 
              placeholder-class="placeholder"
              type="number" 
              maxlength="4" 
              value="{{verifyCode}}" 
              bindinput="onVerifyCodeInput" 
            />
          </view>
          <view class="verify-code-box" bindtap="refreshVerifyCode">
            <image wx:if="{{verifyCodeImage}}" src="{{verifyCodeImage}}" mode="aspectFill" class="code-img" />
            <view wx:else class="code-placeholder">点击刷新</view>
          </view>
        </view>
      </view>

      <!-- 子女注册需要输入老人 UID -->
      <view class="input-group" wx:if="{{showUidInput}}">
        <view class="input-label">老人 UID</view>
        <view class="input-wrapper">
          <input 
            class="input" 
            placeholder="请输入老人的 UID" 
            placeholder-class="placeholder"
            value="{{elderUid}}" 
            bindinput="onElderUidInput" 
          />
        </view>
        <view class="uid-tip">💡 需要向老人索要 UID 才能完成绑定</view>
      </view>

      <!-- 基本信息（仅老人注册显示） -->
      <view class="input-group" wx:if="{{userType === 'elder'}}">
        <view class="input-label">血型</view>
        <picker bindchange="onBloodTypeChange" value="{{bloodTypeIndex}}" range="{{bloodTypes}}">
          <view class="picker {{bloodType ? '' : 'placeholder'}}">
            {{bloodType || '请选择血型'}}
          </view>
        </picker>
      </view>

      <view class="input-group" wx:if="{{userType === 'elder'}}">
        <view class="input-label">紧急联系电话</view>
        <view class="input-wrapper">
          <input class="input" placeholder="请输入家人联系方式" placeholder-class="placeholder" type="number" maxlength="11" value="{{emergencyContact}}" bindinput="onEmergencyContactInput" />
        </view>
      </view>

      <view class="input-group" wx:if="{{userType === 'elder'}}">
        <view class="input-label">家庭地址</view>
        <view class="input-wrapper">
          <input class="input" placeholder="请输入家庭所在地址" placeholder-class="placeholder" value="{{address}}" bindinput="onAddressInput" />
        </view>
      </view>

      <button class="register-btn" hover-class="btn-hover" bindtap="handleRegister">
        立即注册
      </button>

      <view class="footer-links">
        <view class="login-link" bindtap="goToLogin">
          已有账号？<text class="highlight">立即登录</text>
        </view>
      </view>
    </scroll-view>
  </view>
  
  <view class="decoration-circle circle-1"></view>
  <view class="decoration-circle circle-2"></view>
</view>