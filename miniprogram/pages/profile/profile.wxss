page {
  background: #f8fafc;
}

.container {
  min-height: 100vh;
  position: relative;
  padding: 0;
}

/* 顶部背景 */
.header-bg {
  background: linear-gradient(135deg, #fb923c 0%, #ea580c 100%);
  padding-top: 60rpx;
  padding-bottom: 120rpx;
  display: flex;
  justify-content: center;
}

.profile-header {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-container {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  overflow: hidden;
  border: 8rpx solid rgba(255, 255, 255, 0.3);
  margin-bottom: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.avatar-tip {
  position: absolute;
  bottom: -30rpx;
  background: rgba(0, 0, 0, 0.6);
  color: white;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  white-space: nowrap;
}

.nickname {
  font-size: 40rpx;
  font-weight: 800;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 24rpx;
}

.uid-tag {
  background: rgba(255, 255, 255, 0.95);
  padding: 10rpx 28rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #ea580c;
  font-weight: 700;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  border: none;
}

.uid-tag:active {
  background: rgba(255, 255, 255, 0.8);
  transform: scale(0.98);
}

.copy-icon {
  font-size: 24rpx;
  color: #fb923c;
}

/* 底部白色卡片 */
.content-sheet {
  background: white;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  margin-top: -60rpx;
  padding: 50rpx 40rpx;
  min-height: calc(100vh - 300rpx);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 40rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 32rpx;
  background: #f97316;
  border-radius: 4rpx;
}

.form-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 30rpx;
  border-radius: 24rpx;
  border: 2rpx solid #f1f5f9;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.02);
  transition: all 0.3s;
}

.form-item:focus-within {
  border-color: #fb923c;
  box-shadow: 0 8rpx 24rpx rgba(251, 146, 60, 0.15);
  background: #fff;
  transform: translateY(-2rpx);
}

.form-item.align-top {
  align-items: flex-start;
}

.item-icon {
  width: 80rpx;
  font-size: 40rpx;
  display: flex;
  justify-content: center;
  margin-right: 20rpx;
}

.item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.input, .picker {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
  height: 48rpx;
  line-height: 48rpx;
}

.textarea {
  font-size: 32rpx;
  color: #1e293b;
  font-weight: 600;
  width: 100%;
  height: 120rpx;
  line-height: 1.4;
}

.placeholder {
  color: #cbd5e1;
  font-weight: 400;
}

.arrow {
  font-size: 32rpx;
  color: #cbd5e1;
  font-weight: 800;
  margin-left: 20rpx;
}

.button-section {
  margin-top: 80rpx;
  padding-bottom: 40rpx;
}

.save-btn {
  background: linear-gradient(135deg, #f97316, #ea580c);
  color: white;
  border-radius: 60rpx;
  font-size: 36rpx;
  font-weight: 800;
  padding: 30rpx 0;
  box-shadow: 0 12rpx 24rpx rgba(234, 88, 12, 0.25);
  border: none;
  letter-spacing: 2rpx;
}

.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 12rpx rgba(234, 88, 12, 0.2);
}