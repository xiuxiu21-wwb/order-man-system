<view class="container">
  <!-- 顶部背景区 -->
  <view class="header-bg">
    <view class="profile-header">
      <view class="avatar-container" bindtap="chooseAvatar">
        <image wx:if="{{avatarUrl}}" src="{{avatarUrl}}" class="avatar" mode="aspectFill" />
        <open-data wx:else type="userAvatarUrl" class="avatar"></open-data>
        <view class="avatar-tip">点击更换头像</view>
      </view>
      <view class="nickname-container">
        <text class="nickname">{{profile.name || '微信用户'}}</text>
      </view>
      <!-- UID 显示 -->
      <view class="uid-tag" bindtap="copyUid" wx:if="{{uid}}">
        <text>ID: {{uid}}</text>
        <text class="copy-icon">❐</text>
      </view>
    </view>
  </view>

  <!-- 内容卡片区 -->
  <view class="content-sheet">
    <view class="section-title">基本资料</view>
    
    <view class="form-list">
      <view class="form-item">
        <view class="item-icon">📝</view>
        <view class="item-content">
          <text class="label">姓名</text>
          <input class="input" placeholder="请输入姓名" placeholder-class="placeholder" value="{{profile.name}}" bindinput="onInputName" />
        </view>
      </view>
      
      <view class="form-item">
        <view class="item-icon">🩸</view>
        <view class="item-content">
          <text class="label">血型</text>
          <picker bindchange="onBloodTypeChange" value="{{bloodTypeIndex}}" range="{{bloodTypes}}">
            <view class="picker {{profile.bloodType ? '' : 'placeholder'}}">
              {{profile.bloodType || '请选择血型'}}
            </view>
          </picker>
        </view>
        <view class="arrow">></view>
      </view>

      <view class="form-item">
        <view class="item-icon">📞</view>
        <view class="item-content">
          <text class="label">紧急联系</text>
          <input class="input" placeholder="请输入家人联系方式" placeholder-class="placeholder" value="{{profile.emergencyContact}}" bindinput="onInputContact" />
        </view>
      </view>

      <view class="form-item align-top">
        <view class="item-icon">🏠</view>
        <view class="item-content">
          <text class="label">家庭地址</text>
          <textarea class="textarea" placeholder="请输入家庭所在地址" placeholder-class="placeholder" value="{{profile.address}}" bindinput="onInputAddress" disable-default-padding="{{true}}" />
        </view>
      </view>
    </view>

    <view class="button-section">
      <button class="save-btn" hover-class="btn-hover" bindtap="saveProfile">保存修改</button>
    </view>
  </view>
</view>