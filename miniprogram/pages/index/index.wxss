page {
  height: 100vh;
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  overflow: hidden;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  padding: 0;
}

.header-content {
  padding-top: 120rpx;
  text-align: center;
  margin-bottom: 60rpx;
  animation: fadeInDown 0.8s ease-out;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.logo-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
  display: inline-block;
  animation: bounce 2s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.app-title {
  font-size: 40rpx;
  font-weight: 800;
  color: white;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 8rpx rgba(0, 0, 0, 0.1);
}

.app-slogan {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 4rpx;
  font-weight: 500;
}

.card-container {
  width: 660rpx;
  background: white;
  border-radius: 40rpx;
  padding: 50rpx 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.section-title {
  text-align: center;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 50rpx;
  position: relative;
}

.card-grid {
  display: flex;
  justify-content: space-between;
  margin-bottom: 50rpx;
}

.role-card {
  width: 270rpx;
  height: 320rpx;
  background: #fff7ed;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx solid transparent;
  transition: all 0.3s;
  position: relative;
  overflow: hidden;
}

.role-card:active {
  transform: scale(0.96);
  background: #ffedd5;
  border-color: #fb923c;
}

.role-icon-bg {
  width: 140rpx;
  height: 140rpx;
  background: #f97316;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(249, 115, 22, 0.3);
}

.role-icon-bg.family {
  background: #f59e0b;
  box-shadow: 0 8rpx 20rpx rgba(245, 158, 11, 0.3);
}

.role-emoji {
  font-size: 70rpx;
}

.role-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #4b5563;
}

.divider-box {
  display: flex;
  align-items: center;
  margin: 40rpx 0;
}

.line {
  flex: 1;
  height: 2rpx;
  background: #e5e7eb;
}

.text {
  margin: 0 20rpx;
  color: #9ca3af;
  font-size: 26rpx;
}

.action-links {
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.link-item {
  font-size: 30rpx;
  font-weight: 600;
  padding: 20rpx;
}

.link-item.primary {
  color: #ea580c;
}

.link-item.secondary {
  color: #6b7280;
  font-size: 28rpx;
}

.footer-info {
  position: absolute;
  bottom: 60rpx;
  text-align: center;
  width: 100%;
  opacity: 0.8;
}

.copyright {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.slogan {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.6);
  letter-spacing: 2rpx;
}
