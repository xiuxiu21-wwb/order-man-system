page {
  height: 100%;
  background: #f5f5f5;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 30rpx;
  background: #fff;
  border-bottom: 1rpx solid #eee;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.message-area {
  flex: 1;
  padding: 30rpx;
}

.message {
  display: flex;
  margin-bottom: 30rpx;
  align-items: flex-start;
}

.message.user {
  flex-direction: row-reverse;
}

.avatar {
  font-size: 60rpx;
  margin: 0 20rpx;
}

.bubble {
  max-width: 70%;
}

.text {
  background: #fff;
  padding: 20rpx 25rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.message.user .text {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
}

.time {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.message.user .time {
  text-align: right;
}

.typing {
  display: flex;
  gap: 8rpx;
  padding: 20rpx 25rpx;
  background: #fff;
  border-radius: 20rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #999;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-10rpx);
  }
}

.quick-area {
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  gap: 15rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.quick-btn {
  padding: 15rpx 25rpx;
  background: #f0f9ff;
  color: #0369a1;
  border-radius: 30rpx;
  font-size: 24rpx;
  flex-shrink: 0;
}

.footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom, 0));
  background: #fff;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.input-box {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  background: #e5e5e5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  display: block;
}

.send {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #fff;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  margin: 0;
  border: none;
  flex-shrink: 0;
  white-space: nowrap;
}

.send::after {
  border: none;
}

/* UID 水印样式 */
.uid-watermark {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to right, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.95));
  color: white;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  z-index: 9999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.uid-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 100%;
}

.uid-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.uid-text {
  flex: 1;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-right: 20rpx;
}

.uid-copy {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.uid-copy:active {
  background: rgba(255, 255, 255, 0.3);
}
