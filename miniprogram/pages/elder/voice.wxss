page {
  height: 100vh;
  background: #fdfaf8;
  display: flex;
  flex-direction: column;
}

.container {
  padding: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 背景图片 */
.background-image {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100vw;
  height: 100vh;
  z-index: -1;
  pointer-events: none;
}

/* 导航栏 */
.nav-header {
  padding: 100rpx 40rpx 30rpx;
  background: rgba(255, 255, 255, 0.3);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.nav-status {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: rgba(243, 244, 246, 0.5);
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #10b981;
}

.status-dot.typing {
  background: #f59e0b;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% { opacity: 0.5; }
  50% { opacity: 1; }
  100% { opacity: 0.5; }
}

.status-text {
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
}

/* 消息区域 */
.message-area {
  flex: 1;
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  background: transparent;
}

.chat-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100rpx;
  opacity: 0;
  animation: fadeIn 0.8s ease-out forwards;
}

@keyframes fadeIn {
  to { opacity: 1; }
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  background: rgba(255, 255, 255, 0.7);
  width: 180rpx;
  height: 180rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.05);
}

.placeholder-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 12rpx;
}

.placeholder-sub {
  font-size: 26rpx;
  color: #94a3b8;
}

.message-wrapper {
  display: flex;
  align-items: flex-end;
  margin-bottom: 40rpx;
  gap: 20rpx;
}

.message-wrapper.user {
  flex-direction: row-reverse;
}

.avatar-box {
  flex-shrink: 0;
}

.avatar-img {
  width: 80rpx;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.avatar-img.user {
  background: #ffedd5;
}

.message-content {
  max-width: 70%;
  display: flex;
  flex-direction: column;
}

.message-wrapper.user .message-content {
  align-items: flex-end;
}

.bubble {
  padding: 24rpx 32rpx;
  border-radius: 36rpx;
  font-size: 32rpx;
  line-height: 1.5;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.03);
  word-break: break-all;
}

.message-wrapper.ai .bubble {
  background: rgba(255, 255, 255, 0.85);
  color: #1f2937;
  border-bottom-left-radius: 8rpx;
}

.message-wrapper.user .bubble {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-bottom-right-radius: 8rpx;
  box-shadow: 0 8rpx 20rpx rgba(234, 88, 12, 0.2);
}

.meta-info {
  font-size: 22rpx;
  color: #cbd5e1;
  margin-top: 10rpx;
  padding: 0 10rpx;
}

/* 正在输入动画 */
.typing-bubble {
  background: rgba(255, 255, 255, 0.85) !important;
  display: flex;
  gap: 10rpx;
  padding: 30rpx !important;
  border-radius: 36rpx !important;
  border-bottom-left-radius: 8rpx !important;
}

.typing-dot {
  width: 14rpx;
  height: 14rpx;
  background: #cbd5e1;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out both;
}

.typing-dot:nth-child(1) { animation-delay: -0.32s; }
.typing-dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

/* 底部输入区 */
.input-area {
  background: rgba(255, 255, 255, 0.5);
  backdrop-filter: blur(10px);
  padding-bottom: calc(env(safe-area-inset-bottom) + 20rpx);
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.quick-scroll {
  padding: 20rpx 0 10rpx;
  width: 100%;
  white-space: nowrap;
}

.quick-list {
  padding: 0 30rpx;
  display: flex;
  gap: 16rpx;
}

.quick-pill {
  display: inline-block;
  background: rgba(255, 255, 255, 0.6);
  border: 2rpx solid #e5e7eb;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #4b5563;
  font-weight: 600;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.03);
  transition: all 0.2s;
}

.quick-pill:active {
  background: #fff7ed;
  border-color: #fdba74;
  color: #ea580c;
  transform: scale(0.96);
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  gap: 20rpx;
}

.input-wrapper {
  flex: 1;
  background: rgba(243, 244, 246, 0.7);
  border-radius: 44rpx;
  padding: 4rpx 10rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.input-wrapper:focus-within {
  background: rgba(255, 255, 255, 0.9);
  border-color: #fdba74;
  box-shadow: 0 0 0 6rpx rgba(253, 186, 116, 0.15);
}

.chat-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  color: #1f2937;
}

.input-placeholder {
  color: #9ca3af;
}

.send-btn {
  width: 88rpx;
  height: 88rpx;
  background: rgba(229, 231, 235, 0.7);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s;
  flex-shrink: 0;
}

.send-btn.active {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  box-shadow: 0 8rpx 20rpx rgba(234, 88, 12, 0.3);
  transform: rotate(0deg);
}

.send-icon {
  font-size: 40rpx;
  color: white;
  font-weight: 800;
  margin-top: -4rpx;
}

.dot {
  width: 14rpx;
  height: 14rpx;
  background: #cbd5e1;
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.dot:nth-child(2) {
  animation-delay: 0.2s;
}

.dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    transform: translateY(0);
  }
  30% {
    transform: translateY(-10rpx);
  }
}

.quick-area {
  padding: 20rpx 30rpx;
  background: transparent;
  border-top: none;
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
  margin-bottom: 10rpx;
}

.quick-btn {
  padding: 16rpx 30rpx;
  background: #fff;
  color: #ea580c;
  border-radius: 40rpx;
  font-size: 26rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  border: 2rpx solid #ffedd5;
  font-weight: 600;
}

.footer {
  padding: 20rpx 30rpx;
  padding-bottom: calc(30rpx + env(safe-area-inset-bottom, 0));
  background: white;
  border-top: 1rpx solid rgba(0,0,0,0.05);
  display: flex;
  align-items: center;
  gap: 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.02);
}

.input-box {
  flex: 1;
  min-width: 0;
  height: 88rpx;
  background: #f3f4f6;
  border-radius: 44rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  color: #1f2937;
  display: block;
  transition: all 0.3s;
}

.input-box:focus {
  background: #fff;
  border: 2rpx solid #fdba74;
}

.send {
  padding: 0 40rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 700;
  margin: 0;
  border: none;
  flex-shrink: 0;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(234, 88, 12, 0.3);
}

.send:active {
  transform: scale(0.95);
}

/* UID 水印样式 */
.uid-watermark {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to right, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.95));
  color: white;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  z-index: 9999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.uid-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 100%;
}

.uid-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.uid-text {
  flex: 1;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-right: 20rpx;
}

.uid-copy {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.uid-copy:active {
  background: rgba(255, 255, 255, 0.3);
}
