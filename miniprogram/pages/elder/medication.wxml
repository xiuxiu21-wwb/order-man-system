<view class="container">
  <view class="header">
    <view class="title">💊 服药提醒</view>
    <button class="add-btn" bindtap="showAddModal">➕ 添加药品</button>
  </view>

  <!-- 药品列表 -->
  <view class="medication-list">
    <view class="card" wx:for="{{medications}}" wx:key="id">
      <view class="medication-header">
        <view class="medication-name">{{item.name}}</view>
        <view class="medication-actions">
          <view class="medication-status {{item.taken ? 'taken' : 'pending'}}">
            {{item.taken ? '已服用' : '待服用'}}
          </view>
          <button class="delete-btn" bindtap="deleteMedication" data-id="{{item.id}}" wx:if="{{!item.taken}}">🗑️</button>
        </view>
      </view>
      <view class="medication-time">⏰ {{item.time}}</view>
      <view class="medication-desc">{{item.dosage}}</view>
      <button 
        class="take-btn {{item.taken ? 'taken' : ''}}" 
        bindtap="takeMedication" 
        data-id="{{item.id}}"
        disabled="{{item.taken}}"
      >
        {{item.taken ? '✓ 已确认' : '确认服药'}}
      </button>
    </view>

    <!-- 空状态提示 -->
    <view class="empty-state" wx:if="{{medications.length === 0}}">
      <view class="empty-icon">💊</view>
      <view class="empty-text">暂无药品信息</view>
      <view class="empty-hint">点击右上角"添加药品"按钮添加</view>
    </view>
  </view>

  <!-- 服药进度 -->
  <view class="card" wx:if="{{medications.length > 0}}">
    <view class="card-title">今日服药进度</view>
    <view class="progress-container">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <view class="progress-text">{{takenCount}}/{{totalCount}}</view>
    </view>
  </view>

  <!-- 添加药品弹窗 -->
  <view class="modal {{showModal ? 'show' : ''}}" bindtap="hideModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">添加药品</view>
        <button class="modal-close" bindtap="hideModal">✕</button>
      </view>
      
      <view class="form-group">
        <view class="form-label">药品名称</view>
        <input class="form-input" placeholder="请输入药品名称" value="{{newMed.name}}" bindinput="onInputName" />
      </view>

      <view class="form-group">
        <view class="form-label">服用时间</view>
        <picker mode="time" value="{{newMed.time}}" bindchange="onTimeChange">
          <view class="time-picker">{{newMed.time || '选择时间'}}</view>
        </picker>
      </view>

      <view class="form-group">
        <view class="form-label">服用说明</view>
        <input class="form-input" placeholder="如：早餐后服用 1 片" value="{{newMed.dosage}}" bindinput="onInputDosage" />
      </view>

      <view class="modal-buttons">
        <button class="btn-cancel" bindtap="hideModal">取消</button>
        <button class="btn-confirm" bindtap="confirmAdd">确定添加</button>
      </view>
    </view>
  </view>
</view>
