<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-header">
    <view class="nav-title">服药提醒</view>
    <view class="nav-action" bindtap="showAddModal">
      <text class="add-icon">＋</text>
      <text>添加</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view scroll-y class="content-scroll">
    <!-- 进度卡片 -->
    <view class="progress-card" wx:if="{{medications.length > 0}}">
      <view class="progress-info">
        <view class="progress-label">今日进度</view>
        <view class="progress-percent">{{progressPercent}}%</view>
      </view>
      <view class="progress-track">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <view class="progress-detail">已服用 {{takenCount}} / 共 {{totalCount}} 次</view>
    </view>

    <!-- 药品列表 -->
    <view class="medication-list" wx:if="{{medications.length > 0}}">
      <view class="section-header">今日药品</view>
      
      <view class="med-card {{item.todayRemainingCount === 0 ? 'taken' : ''}}" wx:for="{{medications}}" wx:key="id">
        <view class="med-status-line"></view>
        <view class="med-content">
          <view class="med-header">
            <view class="med-time-badge">
              <text class="time-icon">⏰</text>
              <text>每日 {{item.times.length}} 次</text>
            </view>
            <view class="med-status-badge {{item.todayRemainingCount === 0 ? 'taken' : 'pending'}}">
              {{item.todayRemainingCount === 0 ? '今日已完成' : '剩 ' + item.todayRemainingCount + ' 次'}}
            </view>
          </view>
          
          <view class="med-body">
            <view class="med-name">{{item.name}}</view>
            <view class="med-dosage">{{item.dosage}}</view>
            <view class="med-remaining" wx:if="{{item.remainingDays !== undefined}}">
              剩余 {{item.remainingDays}} 天
            </view>
          </view>
          
          <view class="med-footer">
            <view class="action-btn delete" bindtap="deleteMedication" data-id="{{item.id}}" wx:if="{{item.todayRemainingCount > 0}}">删除</view>
            
            <view class="time-slots">
              <view class="time-slot {{subItem.taken ? 'done' : ''}}" 
                    wx:for="{{item.todayStatus}}" 
                    wx:for-item="subItem" 
                    wx:key="time"
                    bindtap="{{!subItem.taken ? 'takeMedication' : ''}}" 
                    data-id="{{item.id}}" 
                    data-time="{{subItem.time}}">
                {{subItem.time}} {{subItem.taken ? '✓' : ''}}
              </view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 精致空状态 -->
    <view class="empty-state-card" wx:if="{{medications.length === 0}}">
      <view class="empty-illustration">💊</view>
      <view class="empty-title">暂无服药计划</view>
      <view class="empty-desc">点击右上角“添加”按钮，开启您的健康管理计划</view>
      <button class="empty-btn" bindtap="showAddModal">立即添加</button>
    </view>
  </scroll-view>

  <!-- 添加药品弹窗 -->
  <view class="modal-mask {{showModal ? 'show' : ''}}" bindtap="hideModal">
    <view class="modal-panel" catchtap="stopPropagation">
      <view class="modal-header">
        <view class="modal-title">添加新药品</view>
        <view class="modal-close" bindtap="hideModal">✕</view>
      </view>
      
      <view class="form-container">
        <view class="form-item">
          <view class="form-label">药品名称</view>
          <input class="form-input" placeholder="请输入药品名称" placeholder-class="placeholder" value="{{newMed.name}}" bindinput="onInputName" />
        </view>

        <view class="form-item">
          <view class="form-label">服用时间</view>
          <view class="time-list">
            <view class="time-tag" wx:for="{{newMed.times}}" wx:key="*this" bindtap="removeTime" data-index="{{index}}">
              {{item}} <text class="remove-x">×</text>
            </view>
            <picker mode="time" bindchange="onAddTime">
              <view class="add-time-btn">＋ 添加时间</view>
            </picker>
          </view>
        </view>

        <view class="form-item">
          <view class="form-label">服用说明</view>
          <input class="form-input" placeholder="如：饭后 1 粒" placeholder-class="placeholder" value="{{newMed.dosage}}" bindinput="onInputDosage" />
        </view>

        <view class="form-item">
          <view class="form-label">开始日期</view>
          <picker mode="date" value="{{newMed.startDate}}" start="{{today}}" bindchange="onStartDateChange">
            <view class="form-picker {{newMed.startDate ? '' : 'placeholder'}}">
              {{newMed.startDate || '点击选择开始日期'}}
            </view>
          </picker>
        </view>

        <view class="form-item">
          <view class="form-label">结束日期</view>
          <picker mode="date" value="{{newMed.endDate}}" start="{{newMed.startDate || today}}" bindchange="onEndDateChange">
             <view class="form-picker {{newMed.endDate ? '' : 'placeholder'}}">
              {{newMed.endDate || '点击选择结束日期'}}
            </view>
          </picker>
        </view>

        <button class="submit-btn" bindtap="confirmAdd">确认添加</button>
      </view>
    </view>
  </view>
</view>
