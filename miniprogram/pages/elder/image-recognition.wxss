.container {
  padding: 30rpx;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #6b7280;
}

.image-preview {
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.preview-image {
  width: 100%;
  height: 500rpx;
  border-radius: 12rpx;
}

.upload-placeholder {
  background: white;
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  margin-bottom: 30rpx;
  text-align: center;
  border: 3rpx dashed #d1d5db;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.placeholder-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.placeholder-text {
  font-size: 28rpx;
  color: #6b7280;
}

.action-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.action-btn.secondary {
  background: white;
  color: #374151;
  border: 2rpx solid #e5e7eb;
}

.recognize-btn {
  width: 100%;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 30rpx;
}

.recognize-btn[disabled] {
  background: #d1d5db;
}

.result-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-top: 6rpx solid #10b981;
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.result-text {
  font-size: 30rpx;
  line-height: 1.8;
  color: #374151;
}
