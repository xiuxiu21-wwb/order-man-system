page {
  height: 100vh;
  background: #f8fafc;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  position: relative;
  padding: 0;
}

/* 顶部悬浮导航 */
.nav-header {
  position: absolute;
  top: 100rpx;
  left: 30rpx;
  right: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(20px);
  padding: 24rpx 30rpx;
  border-radius: 40rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  z-index: 10;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #1f2937;
}

.nav-action {
  background: #f3f4f6;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #f97316;
}

.refresh-icon {
  font-size: 28rpx;
}

/* 全屏地图 */
.map-wrapper {
  flex: 1;
  width: 100%;
  position: relative;
}

.map {
  width: 100%;
  height: 100%;
}

/* 底部悬浮面板 */
.bottom-panel {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: auto;
  min-height: 35vh;
  background: white;
  border-top-left-radius: 50rpx;
  border-top-right-radius: 50rpx;
  box-shadow: 0 -10rpx 60rpx rgba(0, 0, 0, 0.08);
  display: flex;
  flex-direction: column;
  z-index: 20;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  padding-bottom: env(safe-area-inset-bottom);
}

.panel-handle {
  width: 80rpx;
  height: 10rpx;
  background: #e2e8f0;
  border-radius: 5rpx;
  margin: 20rpx auto;
}

.panel-content {
  flex: 1;
  padding: 20rpx 40rpx 60rpx;
  box-sizing: border-box;
}

/* 位置卡片 */
.location-card {
  background: white;
  border-radius: 40rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  border: 1rpx solid rgba(0,0,0,0.02);
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.location-card.current {
  background: linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  border: 2rpx solid #e2e8f0;
}

.location-card.home {
  background: linear-gradient(135deg, #fffaf5 0%, #fff7ed 100%);
  border: 2rpx solid #ffedd5;
}

.card-icon {
  width: 90rpx;
  height: 90rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-right: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.06);
}

.card-info {
  flex: 1;
}

.card-label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.card-address {
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
  line-height: 1.4;
}

.card-address.placeholder {
  color: #94a3b8;
  font-weight: 500;
}

.card-detail {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
  line-height: 1.3;
}

.card-action {
  background: #fff;
  padding: 12rpx 30rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #f97316;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(249, 115, 22, 0.15);
  transition: transform 0.2s;
}

.card-action:active {
  transform: scale(0.95);
}

/* 底部导航按钮 */
.navigate-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-radius: 50rpx;
  padding: 30rpx 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 40rpx;
  box-shadow: 0 12rpx 30rpx rgba(234, 88, 12, 0.3);
  border: none;
}

.navigate-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 40rpx;
}

.family-status.offline {
  background: #f3f4f6;
  color: #6b7280;
}

.refresh-btn {
  position: absolute;
  top: 120rpx;
  right: 30rpx;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.action-buttons {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  padding: 30rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.home-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
}

.set-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(234, 88, 12, 0.3);
}

.home-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.home-name {
  font-size: 28rpx;
  color: #374151;
  font-weight: 600;
}

.home-detail {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.home-tips {
  font-size: 22rpx;
  color: #f59e0b;
  margin-top: 5rpx;
}
