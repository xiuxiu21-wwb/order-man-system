.container {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.header {
  padding: 30rpx;
  background: white;
  border-bottom: 1rpx solid #e5e7eb;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.map-container {
  flex: 1;
  position: relative;
}

.map {
  width: 100%;
  height: 100%;
}

.location-info {
  background: white;
  padding: 30rpx;
  border-top: 1rpx solid #e5e7eb;
}

.info-card {
  margin-bottom: 30rpx;
}

.info-card:last-child {
  margin-bottom: 0;
}

.info-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 15rpx;
}

.info-text {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.family-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.family-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.family-avatar {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.family-info {
  flex: 1;
}

.family-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 5rpx;
}

.family-distance {
  font-size: 24rpx;
  color: #6b7280;
}

.family-status {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.family-status.online {
  background: #d1fae5;
  color: #059669;
}

.family-status.offline {
  background: #f3f4f6;
  color: #6b7280;
}

.refresh-btn {
  position: absolute;
  top: 120rpx;
  right: 30rpx;
  background: white;
  padding: 20rpx 30rpx;
  border-radius: 50rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
  z-index: 100;
}

.action-buttons {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  width: 100%;
  padding: 30rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.home-btn {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
}

.set-btn {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
}

.home-info {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.home-name {
  font-size: 28rpx;
  color: #374151;
  font-weight: 600;
}

.home-detail {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.5;
}

.home-tips {
  font-size: 22rpx;
  color: #f59e0b;
  margin-top: 5rpx;
}
