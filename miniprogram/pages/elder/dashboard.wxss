.container {
  padding: 30rpx;
}

.header {
  margin-bottom: 40rpx;
}

.greeting {
  font-size: 44rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.date {
  font-size: 28rpx;
  color: #6b7280;
}

.date-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 8rpx;
  flex-wrap: wrap;
}

.uid-display {
  display: flex;
  align-items: center;
  background: rgba(239, 68, 68, 0.1);
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  gap: 8rpx;
  border: 2rpx solid rgba(239, 68, 68, 0.3);
}

.uid-text {
  font-size: 22rpx;
  color: #dc2626;
  font-weight: 700;
}

.uid-copy-btn {
  font-size: 22rpx;
  color: #dc2626;
  background: rgba(239, 68, 68, 0.2);
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.uid-copy-btn:active {
  background: rgba(239, 68, 68, 0.4);
}

/* 天气卡片样式 */
.weather-card {
  margin-top: 30rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  color: white;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.weather-main {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.weather-icon {
  font-size: 80rpx;
  margin-right: 20rpx;
}

.weather-info {
  flex: 1;
}

.weather-temp {
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1;
  margin-bottom: 8rpx;
}

.weather-text {
  font-size: 28rpx;
  opacity: 0.9;
}

.weather-location {
  font-size: 24rpx;
  opacity: 0.8;
  text-align: right;
  margin-top: 10rpx;
}

.weather-details {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.detail-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.detail-label {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 6rpx;
}

.detail-value {
  font-size: 26rpx;
  font-weight: 600;
}

.weather-forecast {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.forecast-title {
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 15rpx;
  text-align: center;
}

.forecast-list {
  display: flex;
  justify-content: space-around;
}

.forecast-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.1);
  padding: 15rpx 10rpx;
  border-radius: 12rpx;
  min-width: 140rpx;
}

.forecast-date {
  font-size: 22rpx;
  opacity: 0.8;
  margin-bottom: 8rpx;
}

.forecast-weather {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.forecast-temp {
  font-size: 22rpx;
  opacity: 0.9;
}

.weather-loading {
  margin-top: 30rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.loading-spinner {
  font-size: 60rpx;
  margin-bottom: 15rpx;
  animation: spin 2s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #6b7280;
}

.weather-default {
  margin-top: 30rpx;
  background: #f9fafb;
  border-radius: 20rpx;
  padding: 40rpx;
  text-align: center;
}

.weather-default .weather-icon {
  font-size: 60rpx;
  margin-bottom: 10rpx;
}

.weather-default .weather-text {
  font-size: 26rpx;
  color: #9ca3af;
}

.quick-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-card {
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.action-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

.action-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
}

.emergency-section {
  margin-bottom: 40rpx;
}

.emergency-btn {
  width: 100%;
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 40rpx;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 8rpx 24rpx rgba(239, 68, 68, 0.3);
}

.card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.reminder-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.reminder-item:last-child {
  border-bottom: none;
}

.reminder-time {
  font-size: 28rpx;
  font-weight: 600;
  color: #3b82f6;
  width: 120rpx;
  margin-right: 20rpx;
}

.reminder-content {
  font-size: 28rpx;
  color: #374151;
  flex: 1;
}

.empty-reminder {
  text-align: center;
  padding: 40rpx 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #d1d5db;
}

.logout-section {
  margin-top: 40rpx;
}

.logout-btn {
  width: 100%;
  background: #f3f4f6;
  color: #6b7280;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* UID 水印样式 */
.uid-watermark {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to right, rgba(59, 130, 246, 0.95), rgba(37, 99, 235, 0.95));
  color: white;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  z-index: 9999;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.1);
}

.uid-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  max-width: 100%;
}

.uid-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.uid-text {
  flex: 1;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  margin-right: 20rpx;
}

.uid-copy {
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  white-space: nowrap;
}

.uid-copy:active {
  background: rgba(255, 255, 255, 0.3);
}
