<view class="container">
  <view class="header">
    <view class="title">🎤 AI 语音陪伴</view>
  </view>

  <scroll-view scroll-y="true" scroll-into-view="{{scrollToView}}" class="message-area">
    <view wx:for="{{messages}}" wx:key="id" id="msg-{{item.id}}" class="message {{item.isUser ? 'user' : 'ai'}}">
      <view class="avatar">{{item.isUser ? '👴' : '🤖'}}</view>
      <view class="bubble">
        <view class="text">{{item.text}}</view>
        <view class="time">{{item.time}}</view>
      </view>
    </view>
    <view wx:if="{{isTyping}}" class="message ai">
      <view class="avatar">🤖</view>
      <view class="bubble">
        <view class="typing">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="quick-area">
    <view class="quick-btn" wx:for="{{quickQuestions}}" wx:key="index" bindtap="sendQuick" data-text="{{item}}">
      {{item}}
    </view>
  </view>

  <view class="footer">
    <input class="input-box" placeholder="说点什么吧..." value="{{inputText}}" bindinput="onInput" bindconfirm="sendMessage" confirm-type="send"/>
    <button class="send" bindtap="sendMessage">发送</button>
  </view>
</view>
