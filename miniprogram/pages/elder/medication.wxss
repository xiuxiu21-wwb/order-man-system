page {
  background: #f8fafc;
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.container {
  padding: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.nav-header {
  padding: 100rpx 40rpx 40rpx;
  background: white;
  display: flex;
  justify-content: space-between;
  align-items: center;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.nav-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1f2937;
  letter-spacing: 2rpx;
}

.nav-action {
  background: #f3f4f6;
  padding: 12rpx 24rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #f97316;
  transition: all 0.3s;
}

.nav-action:active {
  background: #ffedd5;
  transform: scale(0.96);
}

.add-icon {
  font-size: 32rpx;
  font-weight: 800;
  margin-top: -4rpx;
}

/* 内容滚动区 */
.content-scroll {
  flex: 1;
  padding: 30rpx 40rpx;
  box-sizing: border-box;
}

/* 进度卡片 */
.progress-card {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  border-radius: 40rpx;
  padding: 40rpx;
  color: white;
  margin-bottom: 50rpx;
  box-shadow: 0 12rpx 30rpx rgba(234, 88, 12, 0.25);
  position: relative;
  overflow: hidden;
}

.progress-card::after {
  content: '';
  position: absolute;
  right: -50rpx;
  top: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 32rpx;
  font-weight: 700;
  opacity: 0.9;
}

.progress-percent {
  font-size: 60rpx;
  font-weight: 800;
  line-height: 1;
}

.progress-track {
  height: 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: white;
  border-radius: 6rpx;
  transition: width 0.5s ease;
}

.progress-detail {
  font-size: 24rpx;
  opacity: 0.8;
  text-align: right;
}

/* 药品列表 */
.section-header {
  font-size: 30rpx;
  font-weight: 700;
  color: #64748b;
  margin-bottom: 30rpx;
  padding-left: 10rpx;
}

.med-card {
  background: white;
  border-radius: 36rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  display: flex;
  overflow: hidden;
  transition: all 0.3s;
  border: 2rpx solid transparent;
}

.med-card.taken {
  background: #f8fafc;
  box-shadow: none;
  border-color: #f1f5f9;
}

.med-status-line {
  width: 12rpx;
  background: #fbbf24;
}

.med-card.taken .med-status-line {
  background: #10b981;
}

.med-content {
  flex: 1;
  padding: 30rpx;
}

.med-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.med-time-badge {
  background: #fff7ed;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: #ea580c;
  font-weight: 700;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.med-card.taken .med-time-badge {
  background: #f1f5f9;
  color: #94a3b8;
}

.time-icon {
  font-size: 24rpx;
}

.med-status-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
}

.med-status-badge.pending {
  background: #fef3c7;
  color: #d97706;
}

.med-status-badge.taken {
  background: #d1fae5;
  color: #059669;
}

.med-body {
  margin-bottom: 30rpx;
}

.med-name {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.med-card.taken .med-name {
  color: #94a3b8;
  text-decoration: line-through;
}

.med-dosage {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.med-remaining {
  font-size: 24rpx;
  color: #f97316;
  font-weight: 600;
  background: #fff7ed;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.med-card.taken .med-remaining {
  background: #f1f5f9;
  color: #94a3b8;
}

.med-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 20rpx;
}

.action-btn {
  border-radius: 24rpx;
  padding: 20rpx 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  transition: all 0.3s;
}

.time-slots {
  flex: 1;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-end;
}

.time-slot {
  background: white;
  border: 2rpx solid #fb923c;
  color: #ea580c;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 700;
  transition: all 0.2s;
  box-shadow: 0 4rpx 10rpx rgba(251, 146, 60, 0.15);
}

.time-slot:active {
  transform: scale(0.95);
  background: #fff7ed;
}

.time-slot.done {
  background: #d1fae5;
  border-color: #d1fae5;
  color: #059669;
  box-shadow: none;
  opacity: 0.8;
}

.action-btn.delete {
  width: 100rpx;
  background: #fee2e2;
  color: #ef4444;
  font-size: 24rpx;
  padding: 12rpx 0;
}

/* 空状态卡片 */
.empty-state-card {
  background: white;
  border-radius: 40rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.05);
  margin-top: 40rpx;
}

.empty-illustration {
  font-size: 120rpx;
  margin-bottom: 40rpx;
  display: inline-block;
  animation: float 4s ease-in-out infinite;
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-16rpx); }
}

.empty-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #94a3b8;
  margin-bottom: 60rpx;
  padding: 0 40rpx;
  line-height: 1.6;
}

.empty-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: 700;
  padding: 24rpx 80rpx;
  box-shadow: 0 8rpx 20rpx rgba(234, 88, 12, 0.3);
  border: none;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8rpx);
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s;
}

.modal-mask.show {
  opacity: 1;
  pointer-events: auto;
}

.modal-panel {
  width: 640rpx;
  background: white;
  border-radius: 40rpx;
  padding: 40rpx;
  transform: scale(0.9);
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.modal-mask.show .modal-panel {
  transform: scale(1);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #1f2937;
}

.modal-close {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 10rpx;
}

/* 添加时间相关样式 */
.time-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-top: 10rpx;
}

.time-tag {
  background: #fff7ed;
  color: #ea580c;
  font-weight: 600;
  font-size: 28rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  border: 2rpx solid #ffedd5;
}

.remove-x {
  font-size: 32rpx;
  font-weight: 400;
  line-height: 1;
  color: #f97316;
}

.add-time-btn {
  background: #f1f5f9;
  color: #64748b;
  font-size: 28rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  border: 2rpx dashed #cbd5e1;
  display: flex;
  align-items: center;
}

.add-time-btn:active {
  background: #e2e8f0;
}

.form-item {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #64748b;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

.form-input, .form-picker {
  background: #f8fafc;
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1f2937;
  font-weight: 600;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.form-input:focus {
  background: white;
  border-color: #fb923c;
  box-shadow: 0 0 0 6rpx rgba(251, 146, 60, 0.1);
}

.placeholder {
  color: #cbd5e1;
  font-weight: 400;
}

.submit-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-radius: 30rpx;
  padding: 24rpx 0;
  font-size: 32rpx;
  font-weight: 700;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(234, 88, 12, 0.25);
  border: none;
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: none;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal.show {
  display: flex;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  width: 90%;
  max-width: 600rpx;
  padding: 30rpx;
  animation: slideUp 0.3s;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.modal-close {
  background: none;
  border: none;
  font-size: 40rpx;
  color: #9ca3af;
  padding: 0;
  margin: 0;
  line-height: 1;
  min-width: auto;
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 28rpx;
  color: #374151;
  margin-bottom: 10rpx;
  font-weight: 600;
}

.form-input {
  width: 100%;
  background: #f3f4f6;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.time-picker {
  width: 100%;
  background: #f3f4f6;
  border: 2rpx solid #e5e7eb;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #1f2937;
  box-sizing: border-box;
}

.modal-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.btn-confirm {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  color: white;
  border: none;
}
