<view class="container">
  <!-- 顶部悬浮导航栏 -->
  <view class="nav-header">
    <view class="nav-title">家庭地图</view>
    <view class="nav-action" bindtap="refreshLocation">
      <text class="refresh-icon">🔄</text>
      <text>刷新</text>
    </view>
  </view>

  <!-- 全屏地图容器 -->
  <view class="map-wrapper">
    <map 
      id="map"
      longitude="{{longitude}}"
      latitude="{{latitude}}"
      scale="16"
      show-location="true"
      class="map"
      markers="{{markers}}"
    >
    </map>
  </view>

  <!-- 底部悬浮面板 -->
  <view class="bottom-panel">
    <!-- 拖动指示条 -->
    <view class="panel-handle"></view>

    <scroll-view scroll-y class="panel-content">
      <!-- 当前位置卡片 -->
      <view class="location-card current">
        <view class="card-icon">📍</view>
        <view class="card-info">
          <view class="card-label">当前位置</view>
          <view class="card-address">{{address}}</view>
        </view>
      </view>
      
      <!-- 家的位置卡片 -->
      <view class="location-card home">
        <view class="card-icon home-icon">🏠</view>
        <view class="card-info">
          <view class="card-label">家的位置</view>
          <view class="card-address {{homeAddress ? '' : 'placeholder'}}">
            {{homeAddress || '暂未设置'}}
          </view>
          <view class="card-detail" wx:if="{{homeDetailAddress}}">{{homeDetailAddress}}</view>
        </view>
        <view class="card-action" bindtap="setHomeLocation">
          <text>设置</text>
        </view>
      </view>

      <!-- 底部操作按钮 -->
      <button class="navigate-btn" bindtap="navigateHome">
        <text class="btn-icon">🧭</text>
        <text>一键导航回家</text>
      </button>
    </scroll-view>
  </view>
</view>
