.container {
  min-height: 100vh;
  background: #f3f4f6;
}

.header {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: white;
  border-bottom: 1rpx solid #e5e7eb;
  position: relative;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
}

.badge {
  position: absolute;
  top: 25rpx;
  left: 180rpx;
  background: #ef4444;
  color: white;
  font-size: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 8rpx;
}

.filter-tabs {
  display: flex;
  background: white;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-bottom: 1rpx solid #e5e7eb;
  overflow-x: auto;
}

.filter-tab {
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #6b7280;
  white-space: nowrap;
  background: #f3f4f6;
}

.filter-tab.active {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
}

.alerts-list {
  padding: 20rpx;
}

.alert-item {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border-left: 6rpx solid #d1d5db;
}

.alert-item.emergency {
  border-left-color: #ef4444;
}

.alert-item.warning {
  border-left-color: #f59e0b;
}

.alert-item.info {
  border-left-color: #3b82f6;
}

.alert-item.read {
  opacity: 0.6;
}

.alert-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
}

.alert-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.alert-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  flex: 1;
  margin-right: 20rpx;
}

.alert-time {
  font-size: 24rpx;
  color: #9ca3af;
  white-space: nowrap;
}

.alert-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 15rpx;
}

.alert-tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.alert-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  background: #f3f4f6;
  color: #6b7280;
}

.alert-status {
  margin-left: 15rpx;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #ef4444;
  border-radius: 50%;
}

.empty-state {
  text-align: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #9ca3af;
}
