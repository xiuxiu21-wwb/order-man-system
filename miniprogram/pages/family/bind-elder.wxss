.container {
  padding: 30rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 20rpx;
}

.bound-list {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.elder-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.elder-item:last-child {
  border-bottom: none;
}

.elder-avatar {
  font-size: 60rpx;
  margin-right: 20rpx;
}

.elder-info {
  flex: 1;
}

.elder-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.elder-uid {
  font-size: 24rpx;
  color: #6b7280;
}

.elder-actions {
  margin-left: 20rpx;
}

.btn-delete {
  background: #fee2e2;
  color: #ef4444;
  font-size: 24rpx;
  padding: 10rpx 24rpx;
  border-radius: 12rpx;
  border: none;
}

.bind-form {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #1f2937;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input,
.picker {
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 16rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #1f2937;
}

.picker {
  display: flex;
  align-items: center;
}

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  margin-top: 20rpx;
}

.btn-primary[disabled] {
  background: #d1d5db;
}

.tips {
  background: #fef3c7;
  border-radius: 16rpx;
  padding: 30rpx;
  border-left: 8rpx solid #f59e0b;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  margin-bottom: 16rpx;
}

.tips-content {
  font-size: 24rpx;
  color: #78350f;
  line-height: 1.8;
}
