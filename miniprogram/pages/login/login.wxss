page {
  background: #fff7ed;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  height: 100vh;
  overflow: hidden;
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 0;
  position: relative;
}

.header-section {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: 100rpx;
  position: relative;
  z-index: 2;
}

.logo-circle {
  width: 180rpx;
  height: 180rpx;
  background: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 36rpx rgba(251, 146, 60, 0.2);
  margin-bottom: 40rpx;
  border: 8rpx solid rgba(255, 255, 255, 0.8);
}

.logo-emoji {
  font-size: 100rpx;
}

.app-name {
  font-size: 48rpx;
  font-weight: 800;
  color: #c2410c;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.05);
}

.sub-title {
  font-size: 32rpx;
  color: #ea580c;
  opacity: 0.8;
  font-weight: 500;
}

.login-card {
  background: white;
  border-top-left-radius: 60rpx;
  border-top-right-radius: 60rpx;
  padding: 60rpx;
  padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -10rpx 40rpx rgba(251, 146, 60, 0.1);
  position: relative;
  z-index: 10;
  animation: slideUp 0.6s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.card-title {
  font-size: 44rpx;
  font-weight: 800;
  color: #1f2937;
  margin-bottom: 60rpx;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  color: #4b5563;
  font-weight: 600;
  margin-bottom: 16rpx;
  margin-left: 10rpx;
}

.input-wrapper {
  background: #f9fafb;
  border-radius: 30rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.input-wrapper:focus-within {
  background: white;
  border-color: #fb923c;
  box-shadow: 0 0 0 6rpx rgba(251, 146, 60, 0.15);
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  opacity: 0.8;
}

.input {
  flex: 1;
  font-size: 32rpx;
  color: #1f2937;
  height: 48rpx;
}

.placeholder {
  color: #9ca3af;
  font-size: 30rpx;
}

.login-btn {
  background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
  color: white;
  border-radius: 40rpx;
  padding: 0;
  height: 100rpx;
  line-height: 100rpx;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 60rpx;
  box-shadow: 0 12rpx 24rpx rgba(234, 88, 12, 0.25);
  border: none;
}

.btn-hover {
  transform: scale(0.98);
  box-shadow: 0 6rpx 12rpx rgba(234, 88, 12, 0.2);
}

.footer-links {
  margin-top: 40rpx;
  text-align: center;
}

.register-link {
  font-size: 28rpx;
  color: #6b7280;
  padding: 20rpx;
}

.highlight {
  color: #ea580c;
  font-weight: 700;
  margin-left: 10rpx;
}

/* 装饰圆圈 */
.decoration-circle {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  z-index: 1;
}

.circle-1 {
  width: 400rpx;
  height: 400rpx;
  background: rgba(253, 186, 116, 0.3);
  top: -100rpx;
  left: -100rpx;
}

.circle-2 {
  width: 300rpx;
  height: 300rpx;
  background: rgba(254, 215, 170, 0.4);
  top: 20%;
  right: -50rpx;
}